# Jarvis Voice — Mac Test Environment
# Copy to .env.mac-test: cp .env.mac-test.example .env.mac-test
#
# This is an ISOLATED test config. Use a separate Discord test bot so you
# don't disrupt your production Jarvis instance.
#
# Run: ./scripts/mac-test.sh

# ── Test Discord bot (SEPARATE from production) ───────────────────────────────
# Create a test bot at https://discord.com/developers/applications
DISCORD_TOKEN=

# A test server where you have a voice channel
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_TEXT_CHANNEL_ID=

# Your Discord user ID
ALLOWED_USERS=

# ── OpenClaw (optional for testing — can use a local or staging instance) ─────
CLAWDBOT_GATEWAY_URL=http://127.0.0.1:22100
CLAWDBOT_GATEWAY_TOKEN=

# ── Alert webhook ─────────────────────────────────────────────────────────────
ALERT_WEBHOOK_TOKEN=test-token-change-me

# ── STT: mlx-whisper on Apple Silicon ─────────────────────────────────────────
# mac-test.sh starts mlx-whisper server automatically on port 8765
STT_PROVIDER=mlx-whisper
MLX_WHISPER_URL=http://localhost:8765/transcribe

# ── TTS: Piper (CPU ONNX, started by mac-test.sh) ────────────────────────────
PIPER_ENABLED=true
PIPER_URL=http://localhost:3336
PIPER_MODEL=medium

# Edge TTS fallback if Piper fails
EDGE_TTS_VOICE=en-AU-WilliamNeural

# ── Speaker verification (optional for test — CPU/MPS) ───────────────────────
# Set to true only if you have an enrolled voiceprint at ~/.jarvis/
SPEAKER_VERIFY_ENABLED=false
SPEAKER_VERIFY_URL=http://localhost:8767/verify
SPEAKER_DIARIZE_URL=http://localhost:8767/diarize
SPEAKER_THRESHOLD=0.45

# ── Wake word ─────────────────────────────────────────────────────────────────
WAKE_WORD=Jarvis
WAKE_WORD_FUZZY=true
WAKE_WORD_FUZZY_REQUIRE_SPEAKER=false   # relaxed for testing without enrolled voiceprint

# ── Alert webhook bind ────────────────────────────────────────────────────────
ALERT_WEBHOOK_HOST=localhost
ALERT_WEBHOOK_PORT=3335

# ── Bot behavior ──────────────────────────────────────────────────────────────
# Start in IDLE so you need the wake word (safer for testing)
DEFAULT_STATE=IDLE

# Reduce logging noise in test
NODE_ENV=development

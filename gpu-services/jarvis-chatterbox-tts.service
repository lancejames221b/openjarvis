[Unit]
Description=Jarvis Chatterbox TTS Service (Lance voice clone)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/generic/dev/jarvis-gpu-services
Environment=CHATTERBOX_PORT=3340
Environment=CHATTERBOX_DEFAULT_VOICE=jarvis
Environment=CHATTERBOX_VOICE_JARVIS=/home/generic/dev/voice-clones/jarvis/jarvis_reference_15s.wav
Environment=CHATTERBOX_VOICE_LANCE=/home/generic/dev/voice-clones/lance_reference_15s.wav
Environment=CHATTERBOX_JARVIS_EXAGGERATION=0.35
Environment=CHATTERBOX_JARVIS_CFG_WEIGHT=0.6
Environment=CHATTERBOX_JARVIS_TEMPERATURE=0.7
Environment=CHATTERBOX_LANCE_EXAGGERATION=0.4
Environment=CHATTERBOX_LANCE_CFG_WEIGHT=0.5
Environment=CHATTERBOX_LANCE_TEMPERATURE=0.7
ExecStart=/home/generic/dev/voice-clones/train_venv310/bin/python /home/generic/dev/jarvis-gpu-services/chatterbox_tts_service.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

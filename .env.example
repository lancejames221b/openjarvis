# Jarvis Voice — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# See INSTALL.md for step-by-step setup instructions

# ═══════════════════════════════════════════════════════════════════════
# REQUIRED — Bot will not start without these
# ═══════════════════════════════════════════════════════════════════════

# ── Discord Bot ───────────────────────────────────────────────────────
# Create a SEPARATE bot at https://discord.com/developers/applications
# Required intents: GUILD_VOICE_STATES, GUILDS, GUILD_MESSAGES, MESSAGE_CONTENT
DISCORD_TOKEN=

# Discord IDs — enable Developer Mode (Settings → Advanced), right-click to copy
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_TEXT_CHANNEL_ID=

# Your Discord user ID — only listed users can give commands (comma-separated)
ALLOWED_USERS=

# ── Jarvis Gateway (the brain) ───────────────────────────────────────
# jarvis-gateway.js: the Claude CLI adapter. Run it with:
#   systemctl --user start jarvis-gateway
# Generate a strong token: openssl rand -hex 32
JARVIS_GATEWAY_URL=http://127.0.0.1:22100
JARVIS_GATEWAY_TOKEN=

# ── Alert Webhook ─────────────────────────────────────────────────────
# Sub-agents and cron jobs call POST /speak to deliver results by voice
# Generate a strong token: openssl rand -hex 32
ALERT_WEBHOOK_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL — Working defaults provided, tune as needed
# ═══════════════════════════════════════════════════════════════════════

# ── Discord Channels (optional) ───────────────────────────────────────
# Closed captions channel — enrollment prompts and live transcripts posted here
DISCORD_CC_CHANNEL_ID=
# Activity feed channel — task lifecycle events (defaults to DISCORD_TEXT_CHANNEL_ID)
DISCORD_ACTIVITY_CHANNEL_ID=
# Circuit breaker notification channel — posts when gateway becomes unreachable/recovers (optional)
DISCORD_CIRCUIT_BREAKER_CHANNEL=
# Voice callback channel — where webhook callback responses arrive (defaults to DISCORD_TEXT_CHANNEL_ID)
VOICE_CALLBACK_CHANNEL_ID=
# Record mode channels — for meeting transcription ("Jarvis, start recording")
RECORD_CHANNEL_ID=
RECORD_TEXT_CHANNEL_ID=
# Jarvis bot user ID — used to filter webhook callback messages from the bot itself
JARVIS_BOT_ID=

# ── TTS: Piper (primary) + Edge TTS (fallback) ───────────────────────
# Piper runs in-process as a local HTTP server — no separate service needed
# Voice model: Jarvis British RP clone from huggingface.co/jgkawell/jarvis
# Edge TTS (Microsoft Neural) is the automatic fallback if Piper is unavailable
PIPER_ENABLED=true
# Piper in-process HTTP server URL (started automatically by piper-server.js)
PIPER_URL=http://127.0.0.1:3336
# Voice quality: high (~3.5s synthesis, best quality) | medium (~1.5s, faster)
PIPER_MODEL=high
# Port for the in-process Piper HTTP server
PIPER_PORT=3336
# Bind address for Piper HTTP server (default: localhost only)
PIPER_BIND=127.0.0.1
# Path to the Piper binary (default: ~/.local/bin/piper)
# PIPER_BIN=~/.local/bin/piper
# Edge TTS fallback voice (only used when PIPER_ENABLED=false or Piper is down)
EDGE_TTS_VOICE=en-AU-WilliamNeural
# Path to edge-tts binary (default: ~/.local/bin/edge-tts)
# EDGE_TTS_PATH=~/.local/bin/edge-tts
# Sentence-level TTS chunking — faster time-to-first-word (default: true)
STREAMING_TTS_ENABLED=true

# ── STT: Speech-to-Text ──────────────────────────────────────────────
# Providers (pick one):
#   faster-whisper = local GPU via persistent service on port 8766 (recommended)
#   deepgram       = cloud API, fast, ~$0.0043/min (free $200 credit)
#   mlx-whisper    = offload to a Mac running the MLX Whisper server
#   whisper        = local Whisper CLI (slower, no GPU needed, code default)
#   moonshine      = local CPU, fast
#   vosk           = local CPU, fastest (~100-300ms), lower accuracy
STT_PROVIDER=faster-whisper
# Whisper model size (for whisper CLI provider): tiny | base | small | medium | large-v3
WHISPER_MODEL=large-v3-turbo
# Path to whisper binary (default: ~/.local/bin/whisper)
# WHISPER_PATH=~/.local/bin/whisper
# Silence duration (ms) before treating speech as complete (default: 1500)
VAD_TIMEOUT=1500

# Deepgram API key (only needed when STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# MLX Whisper server URL (only needed when STT_PROVIDER=mlx-whisper)
# Point to your Mac's IP/hostname running the MLX Whisper service
MLX_WHISPER_URL=http://your-mac-host:8765/transcribe

# ── Wake Word ─────────────────────────────────────────────────────────
# false = always listening, respond to any speech (code default)
# true  = only respond after hearing the wake word
VOICE_WAKE_WORD_ENABLED=false
# Startup persona — which personality to load on boot (default: jarvis)
# Available: jarvis, snoop, alfred, hal — or any file in personalities/
VOICE_PERSONA=snoop
# Primary wake word phrase
VOICE_WAKE_WORD=hey jarvis
# Additional trigger phrases (comma-separated, merged with primary)
WAKE_WORD_PHRASES=jarvis,yo jarvis
# Auto-require wake word when non-owner users are in the voice channel (default: true)
WAKE_WORD_AUTO=true
# How long (ms) after a response before wake word is required again
# Code default: 120000 (2 min). Extends to 5 min when follow-up is expected.
CONVERSATION_WINDOW_MS=120000
# Ambient classifier active window: only run haiku-ambient within this many ms of the last
# wake word. Utterances outside this window are silently ignored (no API call).
# Default: 60000 (60s). Set to 0 to disable window-gating (always-on, not recommended).
HAIKU_AMBIENT_WINDOW_MS=60000
# Fuzzy wake word: match vocative pattern ([word], [sentence]) when Whisper mishears "Jarvis"
# Requires SPEAKER_VERIFY_ENABLED=true and enrolled voiceprint (unless WAKE_WORD_FUZZY_REQUIRE_SPEAKER=false)
WAKE_WORD_FUZZY=false                   # Enable vocative pattern matching (set true to activate)
WAKE_WORD_FUZZY_MIN_SENTENCE=8          # Min chars in sentence part (after the comma)
WAKE_WORD_FUZZY_MAX_PREFIX=12           # Max chars in the vocative word
WAKE_WORD_FUZZY_REQUIRE_SPEAKER=true    # Require speaker verify to be confirmed (highly recommended)

# ── Sleep Mode ────────────────────────────────────────────────────────
# Extra sleep trigger words/phrases (comma-separated, appended to built-in patterns)
# Triggers shouldSleep() → FSM transitions to SLEEP state
# Example: SLEEP_WORDS=snooze,not now,i'm busy,take five
SLEEP_WORDS=
# Extra wake-from-sleep phrases (comma-separated, appended to built-in WAKE_UP_PATTERNS)
# Also checked by isWakeUpCommand() when bot is in SLEEP state
# Example: SLEEP_WAKE_WORDS=wake up jarvis,i'm back,rise and shine
SLEEP_WAKE_WORDS=

# ── Voice Behavior ────────────────────────────────────────────────────
# Say "On it" before spawning tool-heavy sub-agents (adds ~1s latency)
# Code default in index.js checks === 'true', so default is OFF
VOICE_ACK_ENABLED=false
# Ultra-fast ack via lightweight model before the main gateway response
# Only fires when VOICE_ACK_ENABLED is also true. Code checks === 'true'.
IMMEDIATE_ACKS_ENABLED=false
# Contextual Jarvis-style ack when a sub-agent is spawned (sessions_spawn).
# Based on actual J.A.R.V.I.S. movie dialogue patterns. Generates a brief,
# contextual spoken ack like "Running an Opus code review on ENG-695, sir."
# Only fires on sub-agent dispatch, not direct answers. Default ON.
# Code checks !== 'false', so default is ON.
AGENT_DISPATCH_ACK_ENABLED=true
# Model used for fast ack generation (gateway resolves alias to actual model)
# ACK_MODEL=claude
# Model used for voice gateway requests
# VOICE_MODEL=claude
# SSE streaming from gateway. Set false for CLI-based providers without SSE support.
# Code checks !== 'false', so default is ON.
VOICE_STREAMING=true
# Narrated hands-free mode — sub-agents send live spoken progress updates
# Toggle by voice: "I'm on the go" / "I'm at my desk"
VOICE_MOBILE_MODE=false
# Visual / Screen mode — Expanse-style: audio in, text out
# All responses appear as rich formatted text in Discord instead of TTS
# Toggle by voice: "visual mode on" / "screen mode" / "voice mode" / "talk to me"
VOICE_VISUAL_MODE=false
# Target channel for visual mode output (optional — defaults to focus channel or VOICE_REPORT_CHANNEL_ID)
# VOICE_VISUAL_CHANNEL=
# Allow multiple users to give commands (not just ALLOWED_USERS)
# ALLOWED_USERS retain admin control (stop, cancel, mode toggles)
MULTI_USER_ENABLED=false
# Max seconds of spoken output before auto-summarization kicks in (default: 20)
MAX_SPOKEN_SECONDS=20
# Milliseconds of near-silent audio prepended before first clip
# Wakes Bluetooth speakers from dead-air sleep instead of clipping first syllable
BT_LEAD_IN_MS=0
# Buffer window (ms) to merge rapid speech fragments before dispatching to brain
UTTERANCE_DEBOUNCE_MS=1000
# Post task lifecycle events to the activity channel (default: true)
# Code checks !== 'false'
ACTIVITY_FEED_ENABLED=true
# Mirror all alerts and voice results to the text channel (default: true)
# Code checks !== 'false'
ALERTS_ALSO_POST_TEXT=true

# ── Alert Webhook (server settings) ──────────────────────────────────
# Bind address for the webhook HTTP server
# Set to your VPN/Tailscale IP or 0.0.0.0 so remote sub-agents can reach it
ALERT_WEBHOOK_HOST=localhost
# Port for the webhook HTTP server (default: 3335)
ALERT_WEBHOOK_PORT=3335
# Webhook callback mode — fire-and-forget via /hooks/agent instead of streaming
# Gateway delivers response via Discord message; voice bot picks it up. Default: false.
WEBHOOK_CALLBACK_MODE=false

# ── Speaker Verification (Voiceprint Auth) ────────────────────────────
# Three-stage neural pipeline: Silero VAD → ECAPA-TDNN → Whisper confidence
# Requires jarvis-speaker-verify.service running (GPU, port 8767)
# Enroll: say "Jarvis, enroll my voice" after enabling
# Code checks !== 'false' so default is ON when the var is unset;
# .env.example ships with false for first-time setup safety
SPEAKER_VERIFY_ENABLED=false
# Strict mode: block ALL voice until a voiceprint is enrolled
# Code checks === 'true', so default is OFF
SPEAKER_VERIFY_STRICT=false
# Speaker verification service URL
SPEAKER_VERIFY_URL=http://localhost:8767/verify
# Speaker diarization service URL (used in record mode for speaker labeling)
SPEAKER_DIARIZE_URL=http://localhost:8767/diarize
# Secret passphrase to force-authenticate without voiceprint match
SPEAKER_PASSPHRASE=
# Label used for the owner/primary speaker in diarization output (default: Owner)
DIARIZATION_OWNER_LABEL=Owner

# ── Self-Mute TTS Queue ──────────────────────────────────────────────
# Queue TTS output when owner self-mutes; offer smart debrief on unmute
MUTE_QUEUE_ENABLED=true
# Skip wake word for the unmute reply (requires speaker verify enrolled)
MUTE_QUEUE_WAKE_BYPASS=true
# Maximum queued entries before oldest low-priority items are dropped
MUTE_QUEUE_MAX=20
# Discard queued entries older than this many ms (default: 1 hour)
MUTE_QUEUE_TTL_MS=3600000
# Treat self-unmute as implicit wake word — no "Jarvis" needed for first command
# Voiceprint must match on first utterance. Normal idle/sleep timers apply after.
# Code checks !== 'false', so default is ON.
UNMUTE_IMPLICIT_WAKE=true

# ── Confidence Filtering (Whisper hallucination rejection) ────────────
# Reject transcripts where Whisper thinks the audio wasn't speech
NO_SPEECH_PROB_THRESHOLD=0.45
# Reject transcripts where Whisper was uncertain (exp of avg_logprob)
CONFIDENCE_THRESHOLD=0.35

# ── Gateway Timeouts ──────────────────────────────────────────────────
# Max time (ms) to wait for a complete voice response (default: 90000 = 90s)
GATEWAY_TIMEOUT_MS=90000
# If no streaming token arrives in this time (ms), Jarvis says "One moment."
# Code default: 8000 (8s)
GATEWAY_FIRST_TOKEN_TIMEOUT_MS=8000

# ── Session / Context ────────────────────────────────────────────────
# Gateway session namespace — ties voice to the same brain as text
SESSION_USER=jarvis-voice-user
# Hooks token for /hooks/agent endpoint (defaults to JARVIS_GATEWAY_TOKEN if unset)
# JARVIS_HOOKS_TOKEN=

# ── Multi-account routing (optional) ─────────────────────────────────
# Lock a Discord channel to a different Claude account profile.
# Profile definitions live in ~/.local/state/jarvis-voice/channel-accounts.json.
# Use scripts/jarvis-admin.js to manage profiles and channel mappings.
# Per-channel user pins: only listed Discord user IDs can speak in the pinned channel.
# JSON format: {"channel:1234567890":["discord_user_id_A","discord_user_id_B"]}
# CHANNEL_USER_PINS={}

# Default model alias sent to the gateway (default: claude)
# The gateway maps this to claude-sonnet-4-6 via MODEL_ALIASES.
# DEFAULT_MODEL=claude

# ── Tunable Thresholds ────────────────────────────────────────────────
# Cooldown (ms) between rebuff messages for unrecognized speakers (default: 60000 = 1 min)
SPEAKER_REBUFF_COOLDOWN_MS=60000
# Window (ms) for transcript deduplication — skips repeat commands within this window (default: 15000)
TRANSCRIPT_DEDUP_MS=15000
# Maximum conversation history entries kept per user (default: 40)
CONVERSATION_HISTORY_MAX=40
# TTS pipeline: number of sentences to pre-generate in parallel (default: 3)
TTS_PIPELINE_CONCURRENCY=3
# TTS batch: min chars before flushing a chunk to the pipeline (default: 40)
TTS_BATCH_MIN_CHARS=40
# TTS batch: max chars before forcing a flush (default: 150)
TTS_BATCH_MAX_CHARS=150
# Task ledger: ms before a dispatched-but-unfinished task is considered orphaned (default: 300000 = 5 min)
TASK_ORPHAN_THRESHOLD_MS=300000
# Task ledger: ms before a STREAM_DONE task triggers a follow-up check (default: 120000 = 2 min)
TASK_FOLLOWUP_THRESHOLD_MS=120000
# Task ledger: max entries before oldest are pruned (default: 100)
TASK_LEDGER_MAX=100
# SCHEDULER_TICK_MS=30000       # How often the scheduler checks for due jobs (default: 30s)

# ── Network ───────────────────────────────────────────────────────────
# Your machine's Tailscale/VPN IP — used as webhook bind address and in
# sub-agent /speak callback URLs. Set this if sub-agents run on other machines.
# If everything runs on localhost, leave unset.
# TAILSCALE_IP=your-tailscale-ip

# ── Mac Integration (optional) ───────────────────────────────────────
# SSH host for Mac-side commands: open URLs, screenshots, Cursor IDE.
# Format: user@hostname or user@ip — e.g. me@192.168.1.50
# Leave unset if you don't use Mac integration.
# MAC_SSH_HOST=
# Path to SSH key for Mac access (default: ~/.ssh/id_rsa)
# MAC_SSH_KEY=~/.ssh/id_rsa

# ── HUD & Voice Thread Reports ────────────────────────────────────────
# Voice Session HUD — live status embed in #hud channel
HUD_ENABLED=true
HUD_CHANNEL_ID=your-hud-channel-id
HUD_DEBOUNCE_MS=2000
# Smart Thread Routing — post voice task output to #hud as threads
# Set to false to disable HUD threading (task results posted as threads in #hud)
VOICE_THREAD_REPORTS=false
VOICE_REPORT_CHANNEL_ID=your-hud-channel-id
# Thread TTL: how long before a new thread is created (in ms, default 2 hours)
VOICE_THREAD_TTL_MS=7200000

# ── Voice message (mic button) transcription ──────────────────────────
# Enabled by default. Uncomment to disable.
# VOICE_MESSAGE_AUTO_REPLY=false
# Restrict to specific channel IDs (comma-separated). Empty = all channels.
# VOICE_MESSAGE_CHANNELS=123456789012345678,987654321098765432

# ── Logging ───────────────────────────────────────────────────────────
# Pino log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info
# Set NODE_ENV=production to disable pino-pretty and emit structured JSON logs
# NODE_ENV=production


# ── Skills (/skill Discord command) ─────────────────────────────────
# Directory containing Claude Code skill folders (each with SKILL.md).
# Defaults to ~/.claude/skills (whatever $HOME is for the running user).
# SKILLS_DIR=/home/youruser/.claude/skills

# ── MCP / mcporter ───────────────────────────────────────────────────
# Path to the mcporter CLI binary (default: mcporter, must be on PATH).
# MCPORTER_PATH=/usr/local/bin/mcporter
# Timeout in ms for any single mcporter call (default: 30000).
# MCP_TIMEOUT_MS=30000
# When a mcporter call requires OAuth re-auth, the bot DMs the owner or
# posts to DISCORD_TEXT_CHANNEL_ID with a clickable authorization link.

# ── /session — Discord tmux shell (OWNER-ONLY, opt-in) ───────────────
# WARNING: Enabling this gives Discord shell access to the server.
# Only enable if you fully trust all users who can reach /session commands.
# SESSION_SHELL_ENABLED=false     # Set to true to enable /session start
# SESSION_MAX=3                   # Max concurrent jv-* tmux sessions
# SESSION_TIMEOUT_MS=1800000      # Inactivity kill timeout ms (default: 30 min)
# CLAUDE_MCP_CONFIG=              # Path to MCP config JSON for spawned claude sessions
#                                 # e.g. /home/youruser/.config/mcporter/claude-mcp.json
#                                 # If set, sessions run: claude --mcp-config <path> --dangerously-skip-permissions
#
# NL session hand-off: channel→box mappings are auto-persisted to data/project-map.json
# when you say phrases like "create a channel called X on <box> and start a claude session".
# Requires DISCORD_GUILD_ID to be set.

# ── Remote boxes — SSH host overrides ─────────────────────────────────
# Override the SSH alias used by shortcut handlers that open apps on remote boxes.
# GAMEZ_SSH_HOST=gamez            # SSH alias for gamez (defaults to "gamez")

# ── /box — multi-box SSH shell ────────────────────────────────────────
# Comma-separated list of name:ssh-alias pairs for /box, /shell, /dir.
# Use "local" as the alias for the box the bot runs on.
# Any SSH alias from ~/.ssh/config works — add as many boxes as you need.
# Format: name:ssh-alias:user (user is optional, falls back to ~/.ssh/config)
# BOXES=generic:local:youruser,mac:mac:youruser,gamez:gamez:youruser
#
# Optional: override the default working directory per box.
# BOX_GENERIC_HOME=/home/youruser
# BOX_MAC_HOME=/Users/youruser
# BOX_GAMEZ_HOME=/home/youruser

# ── ClaudeFlare proxy (optional) ──────────────────────────────────────────────
# Set to route all claude -p calls through the local PII redaction proxy.
# Leave blank to use direct Anthropic API (default).
JARVIS_CLAUDEFLARE_URL=
JARVIS_CLAUDEFLARE_TOKEN=

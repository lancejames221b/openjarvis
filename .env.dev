# jarvis-voice — Dev Environment Config
# Safe placeholder values for local development.

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_TEXT_CHANNEL_ID=your_text_channel_id_here
DISCORD_VOICE_CHANNEL_ID=your_voice_channel_id_here
ALLOWED_USERS=your_discord_user_id_here

# OpenClaw Gateway (AI backend)
GATEWAY_URL=http://host.docker.internal:22100

# TTS — mock in dev, real Chatterbox in prod
USE_MOCK_GPU=true
TTS_SERVICE_URL=http://host.docker.internal:3340
TTS_VOICE=owner

# STT — mock in dev, real Whisper in prod
STT_SERVICE_URL=http://host.docker.internal:8766

# Mac integration (optional)
MAC_SSH_HOST=
OWNER_PHONE=

# Owner config
DIARIZATION_OWNER_LABEL=Owner
OWNER_VOICE_REFERENCE=

# Feature flags
WAKE_WORD_ENABLED=true
VOICE_WAKE_WORD=jarvis
MULTI_USER_ENABLED=false
TASK_AUTO_SLEEP_MS=60000
EXTENDED_CONVERSATION_WINDOW_MS=90000

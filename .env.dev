# jarvis-voice — Dev Environment Config
# Safe placeholder values for local development.
# Copy to .env and fill in real values to run.

# ── Required ──────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_TEXT_CHANNEL_ID=your_text_channel_id_here
DISCORD_VOICE_CHANNEL_ID=your_voice_channel_id_here
ALLOWED_USERS=your_discord_user_id_here

# OpenClaw Gateway (AI backend)
CLAWDBOT_GATEWAY_URL=http://host.docker.internal:22100
CLAWDBOT_GATEWAY_TOKEN=

# Alert webhook
ALERT_WEBHOOK_PORT=3335
ALERT_WEBHOOK_TOKEN=dev-placeholder-token

# Speaker verification (required by startup check)
SPEAKER_VERIFY_URL=http://host.docker.internal:8767/verify

# ── TTS ───────────────────────────────────────────────────────────────
# Piper runs in-process — no external GPU service needed for dev
PIPER_ENABLED=true
TTS_PROVIDER=piper
EDGE_TTS_VOICE=en-AU-WilliamNeural
STREAMING_TTS_ENABLED=true

# ── STT ───────────────────────────────────────────────────────────────
STT_PROVIDER=whisper
STT_SERVICE_URL=http://host.docker.internal:8766

# ── Owner config ──────────────────────────────────────────────────────
DIARIZATION_OWNER_LABEL=Owner
OWNER_VOICE_REFERENCE=

# ── Feature flags ─────────────────────────────────────────────────────
WAKE_WORD_ENABLED=true
VOICE_WAKE_WORD=jarvis
MULTI_USER_ENABLED=false
TASK_AUTO_SLEEP_MS=60000
EXTENDED_CONVERSATION_WINDOW_MS=90000

# ── Tailscale (container doesn't have Tailscale, bind to 0.0.0.0) ────
TAILSCALE_IP=0.0.0.0

{
  "name": "jarvis-voice",
  "version": "1.0.0",
  "description": "Jarvis Discord Voice Bot - Real-time voice assistant",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:old": "node test/test-async-pipeline.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^4.11.3",
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.9",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "openai": "^4.80.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prism-media": "^1.3.5",
    "sodium-native": "^4.0.0",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "vitest": "4.0.18"
  },
  "vitest": {
    "environment": "node",
    "env": {
      "NODE_ENV": "production",
      "WAKE_WORD_PHRASES": "",
      "VOICE_WAKE_WORD_ENABLED": "false",
      "LOG_LEVEL": "silent"
    }
  }
}

# jarvis-voice — Development Container
FROM node:22-slim

# Create generic user matching host UID 1000
RUN groupadd -g 1000 generic && \
    useradd -u 1000 -g generic -m -s /bin/bash generic

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3 python3-pip curl git ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci

COPY src/ ./src/
COPY prompts/ ./prompts/

# Give ownership to generic user
RUN chown -R generic:generic /app

USER generic

ENV NODE_ENV=development
ENV LOG_LEVEL=debug
ENV PATH="/home/generic/.npm-global/bin:/home/generic/.local/bin:${PATH}"

CMD ["node", "--max-old-space-size=2048", "src/index.js"]